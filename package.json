{
  "name": "mongoaio",
  "version": "1.1.0",
  "description": "MongoDB editor with compare & sync feature",
  "author": {
    "name": "Aldin K",
    "email": "kajmovicaldin@outlook.com"
  },
  "main": "main.js",
  "scripts": {
    "start": "node start.js",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "build:win": "electron-builder --win --x64",
    "build:linux": "electron-builder --linux deb AppImage",
    "build:mac": "electron-builder --mac --x64 --arm64"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "mongodb": "^6.3.0"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.mongoAIO.app",
    "productName": "MongoAIO",
    "publish": {
      "provider": "github",
      "owner": "AldinKajmovic",
      "repo": "mongoaio"
    },
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "target": [
        "deb",
        "AppImage"
      ],
      "category": "Development"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "icon.png",
      "category": "public.app-category.developer-tools"
    }
  }
}